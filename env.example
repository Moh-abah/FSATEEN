# Fusateen Frontend Environment Variables
# Copy this file to .env.local and fill in your values

# API Configuration
NEXT_PUBLIC_API_URL=https://fasateen.duckdns.org/api/v1
NEXT_PUBLIC_WS_URL=wss://fasateen.duckdns.org/ws

# Production URLs (override these in production)
# NEXT_PUBLIC_API_URL=https://api.fusateen.com/api/v1
# NEXT_PUBLIC_WS_URL=wss://api.fusateen.com/ws

# App Configuration
NEXT_PUBLIC_APP_NAME=فساتين
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Analytics (optional)
# NEXT_PUBLIC_GA_ID=UA-XXXXXXXXX-X

# Social Links (for SEO)
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/fusateen
NEXT_PUBLIC_TWITTER_URL=https://twitter.com/fusateen

# Feature Flags
NEXT_PUBLIC_ENABLE_CHAT=true
NEXT_PUBLIC_ENABLE_AUCTIONS=true
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true

# Debug Mode (set to false in production)
NEXT_PUBLIC_DEBUG=true



# Firebase Configuration (Web Push Notifications)
# These are safe to expose in browser - they have restricted permissions in GCP
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
NEXT_PUBLIC_VAPID_KEY=
